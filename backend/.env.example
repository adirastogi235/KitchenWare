# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Environment: "development" or "production"
# In production mode, startup will fail if any of SECRET_KEY, RAZORPAY_*,
# MONGODB_URL, or CORS_ORIGINS are still their insecure defaults.
ENVIRONMENT=development

# MongoDB connection string.
# Local dev:   mongodb://localhost:27017
# Atlas prod:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=rasoi_ghar

# JWT signing key — generate with: openssl rand -hex 32
# MUST be changed for production deployment.
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Razorpay credentials (https://dashboard.razorpay.com/app/keys)
# Test mode keys start with rzp_test_, live keys with rzp_live_
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Comma-separated list of allowed frontend origins (no trailing slash).
# Local dev default is fine; in production set to your real domain(s).
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
